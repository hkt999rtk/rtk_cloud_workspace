{
  "schema_version": "1.0",
  "environment": "staging",
  "provider": "linode",
  "service": "account-manager",
  "owner": "platform-operator",
  "description": "Example metadata inventory. This file intentionally contains no secret values.",
  "items": [
    {
      "id": "account-manager-runtime-env",
      "type": "env_file",
      "relative_path": "env/account-manager.env",
      "deployed_to": "/etc/rtk-account-manager/account-manager.env",
      "contains": [
        "database connection settings",
        "JWT signing secrets",
        "token delivery settings"
      ],
      "rotation_required": true,
      "last_rotated": "unknown"
    },
    {
      "id": "platform-admin-bootstrap",
      "type": "env_file",
      "relative_path": "tokens/platform-admin-bootstrap.env",
      "deployed_to": "operator bootstrap only",
      "contains": [
        "platform admin email",
        "platform admin password"
      ],
      "rotation_required": true,
      "last_rotated": "unknown"
    }
  ]
}
